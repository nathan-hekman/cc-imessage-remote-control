{
  "name": "cc-remote-control",
  "version": "0.4.0",
  "description": "Text yourself 'Claude <projectname>'. Your Mac (iMessage) or Linux box (Signal) opens a new local Claude Code session in that project with /remote-control enabled, ready to drive from the Claude mobile app. No chat.db reading.",
  "author": {
    "name": "Nathan Hekman",
    "url": "https://github.com/nathan-hekman"
  },
  "homepage": "https://github.com/nathan-hekman/cc-remote-control",
  "repository": "https://github.com/nathan-hekman/cc-remote-control",
  "license": "MIT",
  "keywords": ["imessage", "signal", "remote-control", "shortcuts", "macos", "linux", "mobile", "ios", "haiku"],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/cc-remote-update-check.js\" >/dev/null 2>&1 &",
            "timeout": 2
          }
        ]
      }
    ]
  }
}
