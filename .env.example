# cc-remote-control config — written to ~/.claude/.cc-remote-env by the
# setup wizard (mode 600). Shared between macOS and Linux installs.

# ---------------------------------------------------------------
# Reply target (macOS only) — Linux skips the reply step entirely.
# ---------------------------------------------------------------
# Phone number (E.164) that receives the confirmation iMessage. Use
# the same number you'll text *from* — Shortcuts triggers on incoming
# messages, the router replies to this number.
REPLY_TARGET="+15551234567"

# Prefix on every reply iMessage. Loop avoidance — the router silently
# drops incoming messages that start with this string so Mac-sent
# replies don't re-trigger the Shortcut. Keep it short and free of the
# literal word "claude" (lowercase) since the trigger is case-insensitive.
REPLY_PREFIX="[CR]"

# Legacy names (still honored for backwards compat with pre-v0.4.0
# configs): IMESSAGE_TARGET, IMESSAGE_PREFIX.

# ---------------------------------------------------------------
# Project search settings (both platforms)
# ---------------------------------------------------------------
# Model used to infer which project to open from the message body.
# Haiku is plenty for this and is cheap + fast.
ROUTER_MODEL="claude-haiku-4-5-20251001"

# Primary projects directory — scanned one level deep for candidate
# project slugs. Default is $HOME/Documents. Always wrap in double
# quotes so $HOME expands and paths with spaces still parse.
PROJECTS_ROOT="$HOME/Documents"

# Optional: comma-separated extra dirs to scan one level deep. Handy
# if you keep some projects nested. Example:
# PROJECTS_ROOT_EXTRA="$HOME/Documents/Other Projects,$HOME/code"
PROJECTS_ROOT_EXTRA=""

# Optional: comma-separated subdir names to skip (matched on basename).
# Dotfiles are always skipped automatically. If PROJECTS_ROOT_EXTRA
# points at a subfolder of PROJECTS_ROOT, add its basename here so it
# isn't scanned twice (once as a project, once as a parent dir).
# Example: PROJECTS_EXCLUDE="logs,Zoom,node_modules,Other Projects"
PROJECTS_EXCLUDE=""

# ---------------------------------------------------------------
# Linux HTTP listener (Linux only — ignored on macOS)
# ---------------------------------------------------------------
# Interface to bind on. Default 127.0.0.1 (localhost-only). Set this
# to your Tailscale IP / hostname for tailnet-only access, or 0.0.0.0
# for LAN access, or keep at 127.0.0.1 if you front it with another
# tunnel (Cloudflare Tunnel, ngrok).
CC_REMOTE_BIND="127.0.0.1"

# Port to listen on.
CC_REMOTE_PORT="8923"

# Shared secret for the Authorization: Bearer <secret> header. The
# iPhone Personal Automation includes this on every POST. The
# listener refuses to start without it set. Generate with:
#   openssl rand -hex 32
CC_REMOTE_SECRET=""
